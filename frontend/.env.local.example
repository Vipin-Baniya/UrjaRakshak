# UrjaRakshak Frontend — Local Development Environment Variables
# Copy this file to .env.local and fill in the values.
# cp .env.local.example .env.local

# Backend API URL (FastAPI backend)
# For local development, this should point to the running backend server.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Node.js backend URL (optional secondary backend)
# NEXT_PUBLIC_NODE_API_URL=http://localhost:4000
