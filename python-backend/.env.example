# UrjaRakshak python-backend — environment variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Application ────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=false
HOST=0.0.0.0
PORT=8001

# ── Database ───────────────────────────────────────────────────
# PostgreSQL (asyncpg)
DATABASE_URL=postgresql://user:password@localhost:5432/urjarakshak

# Supabase example:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# SQLite (local dev / CI — no postgres needed):
# DATABASE_URL=sqlite+aiosqlite:///./urjarakshak.db

# ── Authentication ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Services ────────────────────────────────────────────────
# Set at least one to enable AI interpretation features.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Physics engine ─────────────────────────────────────────────
PHYSICS_TEMPERATURE_CELSIUS=25.0
PHYSICS_MIN_CONFIDENCE=0.5

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for dev)
ALLOWED_ORIGINS=http://localhost:3000,https://urjarakshak.vercel.app
