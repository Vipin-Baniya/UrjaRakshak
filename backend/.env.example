# UrjaRakshak Backend — Environment Variables
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Application ──────────────────────────────────────────────
APP_NAME=UrjaRakshak
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────
# Local PostgreSQL example:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urjarakshak
# Supabase example:
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Security ─────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-plus-character-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://urjarakshak.vercel.app
# Optional regex for dynamic preview URLs (e.g. Vercel preview deployments):
# CORS_ALLOW_ORIGIN_REGEX=https://urjarakshak-.*\.vercel\.app

# ── AI Services (optional) ───────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Features ─────────────────────────────────────────────────
ENABLE_STRICT_ETHICS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_AI_ANALYSIS=false
